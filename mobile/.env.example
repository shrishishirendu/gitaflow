# IMPORTANT — read this carefully.
#
# When running on Expo Go on your phone, "localhost" means the phone itself,
# not your laptop. The phone needs your laptop's LAN IP to reach the backend.
#
# 1. Find your laptop's IP:
#       macOS / Linux:   ipconfig getifaddr en0       (or `ifconfig`)
#       Windows:         ipconfig                     (look for IPv4)
#
# 2. Set it here (no quotes, no trailing slash):
#       EXPO_PUBLIC_API_BASE=http://192.168.1.42:8000
#
# 3. Make sure your phone and laptop are on the SAME Wi-Fi network.
#
# 4. Start the backend with --host 0.0.0.0 so it binds to the LAN, not just
#    localhost:
#       uvicorn app.main:app --reload --host 0.0.0.0 --port 8000
#
# If you're using a simulator (iOS Simulator / Android Emulator), localhost
# usually works — but the LAN IP also works and is the safer default.

EXPO_PUBLIC_API_BASE=http://192.168.1.42:8000
