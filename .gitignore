# ── Secrets — NEVER commit these ─────────────────────────────────────
.env
.env.local
.env.*.local
*.env

# ── Local databases ──────────────────────────────────────────────────
*.db
*.db-journal
*.db-wal
*.db-shm
backend/gitaflow.db

# ── Python ───────────────────────────────────────────────────────────
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.mypy_cache/

# ── Node / Vite / Expo ───────────────────────────────────────────────
node_modules/
dist/
build/
.expo/
.expo-shared/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Vite cache ───────────────────────────────────────────────────────
.vite/
node_modules/.vite/

# ── IDE / OS ─────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# ── Local-only working files ─────────────────────────────────────────
/tmp/
*.tmp
.cache/

# ── Build outputs that shouldn't be committed ────────────────────────
*.zip
mobile/dist/
mobile/web-build/